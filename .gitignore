# ==========================================
# MASTER .GITIGNORE FOR SMART HOME MONOREPO
# ==========================================

# ------------------------------------------
# 1. OS & ENVIRONMENT HIDDEN FILES
# ------------------------------------------
.DS_Store
**/.DS_Store
*.log
Thumbs.db
.env
.venv
env/
venv/
ENV/

# ------------------------------------------
# 2. IDE & EDITOR FILES
# ------------------------------------------
.idea/
.vscode/
*.iml
*.ipr
*.iws
.project
.pydevproject
.settings/

# ------------------------------------------
# 3. BACKEND (Python / FastAPI / PostgreSQL)
# ------------------------------------------
# Byte-compiled / optimized / DLL files
**/__pycache__/
**/*.py[cod]
**/*$py.class

# Python Virtual Environment (CRITICAL)
backend/venv/
backend/env/

# Local Environment Variables
backend/.env

# AI Models (Large files - do not upload to Git)
# We ignore .pt and .weights because they are 50MB+ 
# and should be downloaded/moved manually.
backend/ml_models/*.pt
backend/ml_models/*.onnx
backend/ml_models/*.weights
backend/models/insightface/

# Local Storage (Your intruder images)
# Do not upload your actual security photos to Git!
backend/storage/alerts/*
!backend/storage/alerts/.gitkeep

backend/storage/profile_pictures/*
!backend/storage/profile_pictures/.gitkeep

# ------------------------------------------
# 4. mobile_app (Flutter / Dart)
# ------------------------------------------
# Dart/Pub dependencies
mobile_app/.dart_tool/
mobile_app/.packages
mobile_app/.pub-cache/
mobile_app/.pub/
mobile_app/.metadata
mobile_app/.flutter-plugins
mobile_app/.flutter-plugins-dependencies

# Flutter build folders
mobile_app/build/

# Android specific
mobile_app/android/app/debug
mobile_app/android/app/profile
mobile_app/android/app/release
mobile_app/android/local.properties
mobile_app/android/key.properties
mobile_app/android/*.keystore
mobile_app/android/*.jks

# iOS specific
mobile_app/ios/Flutter/.last_build_id
mobile_app/ios/Flutter/Generated.xcconfig
mobile_app/ios/Flutter/flutter_export_environment.sh

# Generated code and symbolication
mobile_app/**/*.map.json
mobile_app/**/*.symbols
mobile_app/**/doc/api/

# Private planning docs
DATABASE_CONTEXT.md
TECHNICAL_AUDIT.md
MODULE_ROADMAP.md
ROADMAP.md
TODO.md
